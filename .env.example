# estatement-mcp — Environment Variables
# Copy this to ~/.estatement-mcp/.env (or to your project's .env)

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estatements

# PDF downloads directory (default: ~/.estatement-mcp/downloads)
# DOWNLOADS_DIR=/path/to/downloads

# Google OAuth credentials (default: ~/.estatement-mcp/credentials.json)
# GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json

# Google OAuth token (default: ~/.estatement-mcp/token.json)
# GOOGLE_TOKEN_PATH=/path/to/token.json
